# CourtListener API key (https://www.courtlistener.com/profile/tokens/)
COURTLISTENER_API_KEY=your_key_here

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Settings → API → service_role)
# Use service role for writes — never commit this value
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Optional: anon key (read-only fallback)
SUPABASE_ANON_KEY=your_anon_key_here
